{
	"compilerOptions": {
		"composite": true,
		"target": "es2022",
		"lib": ["es2022"],
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"strict": true,
		"module": "nodenext",
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	}
}
