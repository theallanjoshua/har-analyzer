{
	"manifest_version": 3,
	"name": "Haroscope",
	"version": "1.0.4",
	"description": "DevTools extension to capture and analyze HTTP requests",
	"devtools_page": "devtools.html",
	"permissions": ["storage"],
	"icons": {
		"16": "icons/haroscope-16.png",
		"48": "icons/haroscope-48.png",
		"128": "icons/haroscope-128.png"
	},
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/haroscope-16.png",
			"48": "icons/haroscope-48.png",
			"128": "icons/haroscope-128.png"
		}
	}
}
